# Copia este archivo a .env y completa los valores.
# .env NO se sube a GitLab.

# --- Firebase Web (Project settings > Your apps > Web) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# --- Scripts locales (actualizar-resultados, recordar-pronosticos) ---
# JSON completo del service account en una sola linea.
FIREBASE_SERVICE_ACCOUNT=

# Token de https://www.football-data.org/
FOOTBALL_DATA_TOKEN=

# --- Deploy manual con Firebase CLI (opcional, solo local) ---
# Genera con: firebase login:ci
# FIREBASE_TOKEN=
