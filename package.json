{
  "name": "quiniela",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "emulators": "npx firebase-tools emulators:start --only auth,firestore",
    "build": "ng build",
    "build:prod": "node scripts/generate-environment.mjs production && ng build",
    "watch": "ng build --watch --configuration development",
    "setup:local": "node scripts/setup-local.mjs",
    "env:migrate": "node scripts/migrate-env-from-development.mjs",
    "env:development": "node scripts/generate-environment.mjs development",
    "env:production": "node scripts/generate-environment.mjs production",
    "deploy:hosting": "npm run build:prod && firebase deploy --only hosting,firestore:rules",
    "deploy:functions": "node functions/sync-scripts.mjs && firebase deploy --only functions",
    "deploy:all": "npm run build:prod && node functions/sync-scripts.mjs && firebase deploy --only hosting,firestore:rules,functions",
    "actualizar-resultados": "node scripts/actualizar-resultados.mjs",
    "actualizar-resultados:dias": "node scripts/actualizar-resultados.mjs --days=2026-06-12,2026-06-13",
    "recordar-pronosticos": "node scripts/recordar-pronosticos.mjs",
    "test:puntos": "node scripts/calcular-puntos.test.mjs"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/fire": "^18.0.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/router": "^18.2.0",
    "chart.js": "^4.5.1",
    "firebase": "^10.13.0",
    "ng2-charts": "^6.0.1",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.3",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "typescript": "~5.5.4"
  }
}
